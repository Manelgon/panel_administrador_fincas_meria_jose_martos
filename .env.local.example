# =============================================================
# SUPABASE
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service Role key — NUNCA expongas esto en el cliente
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# =============================================================
# EMISOR (datos que aparecen en los PDFs generados)
# Fallback si no están configurados en la tabla company_settings de Supabase
# =============================================================
EMISOR_NAME=Nombre de la empresa
EMISOR_ADDRESS=Dirección completa
EMISOR_CITY=Ciudad
EMISOR_CIF=B00000000

# =============================================================
# WEBHOOKS n8n
# Workflows que se disparan desde la app hacia n8n
# =============================================================

# Envío de documentos por email (certificados, suplidos, varios, fichaje)
EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/send-email

# Informe de comunidad por email
COMMUNITY_REPORT_EMAIL_WEBHOOK=https://your-n8n-instance.com/webhook/community-report

# Listado de carpetas OneDrive (facturas comunidades)
ONEDRIVE_FOLDERS_WEBHOOK=https://your-n8n-instance.com/webhook/onedrive-folders
